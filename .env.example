OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5
APP_URL=https://your-vercel-domain.vercel.app
PUBLIC_SITE_URL=https://your-vercel-domain.vercel.app

# Google OAuth (required for login flow validation)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URL=https://your-vercel-domain.vercel.app/auth/callback

# Optional legacy aliases (kept for compatibility)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=

PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
SUPABASE_URL=https://your-project.supabase.co
# Supabase new server key (recommended)
SUPABASE_SECRET_KEY=your-supabase-secret-key
# Legacy key (optional fallback)
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_PASSWORD=change-this-admin-password
# Frontend must use VITE_SUPABASE_URL (not NEXT_PUBLIC_SUPABASE_URL)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Optional, only needed when running src/server/index.mjs locally.
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173
